<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Pin this repository to nuget.org for deterministic, machine-independent restores.
    All current dependencies are public packages. If private DeepSigma feeds are needed
    later, add the source here and define <packageSourceMapping> (Central Package
    Management requires source mapping when more than one source is configured).
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
